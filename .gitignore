# Secrets / keys (NEVER commit)
*.p8
*.pub
*.pem
*.key
*-key.json
*credentials*.json
service-account*.json
.env
# Bare-named private keys (no extension)
*_key
mirror_key
id_rsa
id_ecdsa
id_ed25519
# Local data & logs
chunks/
*.log
clients/*/data/
# Raw source exports (e.g. the client_agora Telegram dump — 900+ MB, far over GitHub's
# 100 MB push limit; the pipeline derives its sqlite from it, so it lives on disk only)
clients/client_agora/raw_files/*.json
# Python
__pycache__/
*.pyc
.venv/
venv/
# Local portal run (run_local.ps1): throwaway venv + seeded demo data, never committed
.venv-portal/
.local_portal_data/
# push-branch.ps1 remembers your branch name here (per-machine, not shared)
tools/.devname
# OS / editor
.DS_Store
Thumbs.db
desktop.ini
*.ndjson
_run/
# Claude Code harness / session state
.claude/
ATRIUM_ANALYSIS.md
